# Production Environment Configuration
# Copy to .env and customize for your production deployment

APP_NAME="Healthcare SaaS"
APP_ENV=production
APP_KEY=base64:...generate_with_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=notice

# PostgreSQL Configuration (recommended for production)
DB_CONNECTION=pgsql
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=healthcare_saas_prod
DB_USERNAME=app_user
DB_PASSWORD=your_secure_password
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.your-domain.com
SESSION_SECURE_COOKIES=true

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=healthcare_saas_prod

REDIS_CLIENT=phpredis
REDIS_HOST=your-redis-host
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

MAIL_MAILER=postmark
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
POSTMARK_API_KEY=your_postmark_api_key

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-healthcare-saas-bucket
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe Configuration (Production Keys)
STRIPE_KEY=pk_live_...your_production_key
STRIPE_SECRET=sk_live_...your_production_secret
STRIPE_WEBHOOK_SECRET=whsec_...your_webhook_secret

# Stripe subscription plan price IDs (production)
STRIPE_SOLO_PRICE=price_...
STRIPE_CLINIC_PRICE=price_...
STRIPE_ENTERPRISE_PRICE=price_...

# Cashier Configuration
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en

# Security Headers
SECURE_HSTS_MAX_AGE=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# Optional: Slack notifications for errors
SLACK_BOT_USER_OAUTH_TOKEN=xoxb_...
SLACK_BOT_USER_DEFAULT_CHANNEL=#errors
